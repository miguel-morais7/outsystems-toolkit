{
  "manifest_version": 3,
  "name": "OutSystems Toolkit",
  "version": "1.0.0",
  "description": "Inspect and edit OutSystems Reactive and ODC app runtime data — variables, actions, aggregates, roles, data models, and more.",
  "homepage_url": "https://github.com/miguel-morais7/outsystems-toolkit",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Open OutSystems Toolkit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}